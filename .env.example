# Telegram Bot Token（从 BotFather 获取）
BOT_TOKEN=

# 管理员 Telegram Chat ID
# 通过 @userinfobot 获取你的 ID
ADMIN_TG_ID=0

# 客服用户名
SUPPORT_USERNAME=admin

# 订单过期时长（分钟）
ORDER_DURATION_MINUTES=30

# Web 服务
WEB_HOST=0.0.0.0
WEB_PORT=8001
DATABASE_PATH=./faka.db

# 支付模式: simulate（模拟）/ epay（易支付）
PAYMENT_MODE=simulate

# 易支付配置（可选）
EPAY_PID=
EPAY_KEY=
EPAY_URL=
EPAY_NOTIFY_URL=
